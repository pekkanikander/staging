---
import { navigation, siteTitle } from '../site';

const normalizePath = (path: string) => {
	if (path !== '/' && path.endsWith('/')) {
		return path.slice(0, -1);
	}

	return path;
};

const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
	<div class="container header-inner">
		<a class="site-brand" href="/">{siteTitle}</a>
		<nav aria-label="Päävalikko">
			<ul class="site-nav">
				{
					navigation.map((item) => {
						const hasChildren = Boolean(item.children?.length);
						const isActive = item.href === currentPath;

						if (hasChildren) {
							const isOpen =
								isActive ||
								item.children!.some((child) => child.href === currentPath);

							return (
								<li class="site-nav-group">
									<details open={isOpen}>
										<summary class={item.href ? 'has-link' : isOpen ? 'is-active' : undefined}>
											{item.href ? (
												<a class={isOpen ? 'is-active' : undefined} href={item.href}>
													{item.label}
												</a>
											) : (
												item.label
											)}
										</summary>
										<ul class="site-subnav">
											{
												item.children!.map((child) => {
													const isChildActive = currentPath === child.href;

													return (
														<li>
															<a
																class={isChildActive ? 'is-active' : undefined}
																href={child.href}
															>
																{child.label}
															</a>
														</li>
													);
												})
											}
										</ul>
									</details>
								</li>
							);
						}

						return (
							<li>
								<a class={isActive ? 'is-active' : undefined} href={item.href}>
									{item.label}
								</a>
							</li>
						);
					})
				}
			</ul>
		</nav>
	</div>
</header>
