---
import { navigation, siteTitle } from '../site';

const currentPath = Astro.url.pathname;

const isGroup = (
	item: (typeof navigation)[number]
): item is Extract<(typeof navigation)[number], { children: unknown }> => {
	return 'children' in item;
};
---

<header class="site-header">
	<div class="container header-inner">
		<a class="site-brand" href="/">{siteTitle}</a>
		<nav aria-label="Päävalikko">
			<ul class="site-nav">
				{
					navigation.map((item) => {
						if (isGroup(item)) {
							const isOpen = item.children.some((child) => currentPath === child.href);

							return (
								<li class="site-nav-group">
									<details open={isOpen}>
										<summary class={isOpen ? 'is-active' : undefined}>{item.label}</summary>
										<ul class="site-subnav">
											{
												item.children.map((child) => {
													const isChildActive = currentPath === child.href;

													return (
														<li>
															<a
																class={isChildActive ? 'is-active' : undefined}
																href={child.href}
															>
																{child.label}
															</a>
														</li>
													);
												})
											}
										</ul>
									</details>
								</li>
							);
						}

						const isActive = currentPath === item.href;

						return (
							<li>
								<a class={isActive ? 'is-active' : undefined} href={item.href}>
									{item.label}
								</a>
							</li>
						);
					})
				}
			</ul>
		</nav>
	</div>
</header>
